(env
 (release
  (menhir
   (flags :standard --strict))))

(ocamllex
 (modules orchestratorLexer))

(ocamllex
 (modules contractLexer))

(menhir
 (modules orchestratorParser exprParser)
 (merge_into orchestratorParser))

(menhir
 (modules contractParser exprParser)
 (merge_into contractParser)
 (flags --unused-token NONDET))

(library
 (name expr)
 (modules expr exprAST expr_pp)
 (modules_without_implementation exprAST))

(library
 (name contract)
 (modules contract contractAST contractAST_pp contractLexer contractParser)
 (modules_without_implementation contractAST)
 (libraries expr utils))

(library
 (name orchestrator)
 (modules
  orchestrator
  orchestratorAST
  orchestratorAST_pp
  orchestratorLexer
  orchestratorParser
  symbolicInterpreter
  orchestratorUtils)
 (modules_without_implementation orchestratorAST)
 (libraries soteria expr contract policyChecker utils)
 (preprocess
  (pps soteria.ppx))
 (flags :standard -open Soteria.Logs.Import))

(library
 (name policyChecker)
 (modules policyChecker)
 (libraries contract soteria))

(library
 (name utils)
 (modules utils))
