int get := 1;
int pay := 2;
int price := 0 - 1;
int nonce := int?;

assume well_formed(user) && well_formed(pass) && fresh(nonce) && !locked(user) && attempts(user) < MAX_ATTEMPTS;
rcpt auth := invoke Auth(user, pass, nonce);

if (auth.successful) then {
  int num_operations := int?;
  assume num_operations > 0 && num_operations <= 3;
  
  while num_operations > 0 do {
    int action := int?;
    assume action == get || action == pay;

    if action == get then {
      int prod_id := int?;
      assume well_formed(prod_id);

      rcpt price_rcpt := invoke GetPrice(prod_id);
      assert price_rcpt.successful;

      price := price_rcpt.retval;
    } else {
      invoke Pay(price);
    }

    num_operations := num_operations - 1;
  }
}
