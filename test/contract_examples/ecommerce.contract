{
    globals: [
        MAX_ATTEMPTS: int
    ],
    functions: [
        attempts: int -> int,
        AuthFee: int -> int,
        GetToken: int -> int -> int,
        PayFee: int -> int
    ],
    QoS: [
        latency: int, 
        cost: int
    ], 
    policies: [
        sum(cost) < 100,
        avg(latency) < 50,
        sorted(trust),
        min(trust) > 10,
        write . write . write . write
    ],
    services: [
        {
            name: Auth,
            params: [
                userId: int,
                password: int,
                nonce: int
            ],
            returns: [token: int],
            trusted: 30,
            precond: [
                wellFormed(userId) = 1,
                wellFormed(password) = 1,
                fresh(nonce) = 1,
                locked(userId) = 0,
                attempts(userId) < MAX_ATTEMPTS
            ],
            QoS: {
                effects: [
                    cost := AuthFee(userId)
                ],
                constraints: [
                    latency <= 10
                ]
            },
            ok-postcond: {
                effects: [
                    token := GetToken(userId, nonce),
                    attempts := 0,
                    budget := budget - 10
                ],
                constraints: [
                    succ = True,
                    verify(userId, password) = 1
                ]
            },
            err-postcond: {
                effects: [
                    token := err
                ],
                constraints: [
                    succ = False
                ]
            }
        },
        {
            name: Pay,
            params: [
                amt: int
            ],
            returns: [r: bool],
            trusted: 23,
            precond: [
                amt > 0
            ],
            QoS: {
                effects: [
                    cost := PayFee(amt)
                ],
                constraints: [
                    latency > 0
                ]
            },
            ok-postcond: {
                effects: [],
                constraints: [
                    succ = True,
                    r = ok
                ]
            },
            err-postcond: {
                effects: [],
                constraints: [
                    succ = False,
                    r = err
                ]
            }
        },
        {
            name: GetPrice,
            params: [
                productId: int
            ],
            returns: [price: int],
            trusted: 7,
            precond: [
                wellFormed(productId) = 1
            ],
            QoS: {
                effects: [],
                constraints: [
                    latency <= 10,
                    cost <= 100
                ]
            },
            ok-postcond: {
                effects: [],
                constraints: [
                    succ = True,
                    price > 0
                ]
            },
            err-postcond: {
                effects: [],
                constraints: [
                    succ = False,
                    price = err
                ]
            }
        }
    ]
}