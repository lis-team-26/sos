{
    globals: [
        MAX_ATTEMPTS: int
    ],
    functions: [
        attempts: int -> int,
        AuthFee: int -> int,
        GetToken: int -> int -> int,
        PayFee: int -> int
    ],
    QoS: [
        latency: int, 
        cost: int,
        trust: int
    ], 
    policies: [
        sum(cost) < 100,
        avg(latency) < 50,
        sorted(trust),
        min(trust) > 10,
        {Auth -> a, Pay -> p, GetPrice -> g} "[^a]|a[apg]*pp"
    ],
    services: [
        {
            name: Auth,
            params: [
                userId: int,
                password: int,
                nonce: int
            ],
            returns: { token: int },
            precond: [
                wellFormed(userId) = 1,
                wellFormed(password) = 1,
                fresh(nonce) = 1,
                locked(userId) = 0,
                attempts(userId) < MAX_ATTEMPTS
            ],
            QoS-postcond: {
                effects: [
                    cost := AuthFee(userId)
                ],
                constraints: [
                    latency <= 10,
                    cost <= 10,
                    trust > 10
                ]
            },
            ok-postcond: {
                effects: [
                    token := GetToken(userId, nonce),
                    attempts := 0,
                    budget := budget - 10
                ],
                constraints: [
                    succ = True,
                    verify(userId, password) = 1
                ]
            },
            err-postcond: {
                effects: [
                    token := err
                ],
                constraints: [
                    succ = False
                ]
            }
        },
        {
            name: Pay,
            params: [
                amt: int
            ],
            returns: { r: bool },
            precond: [
                amt > 0
            ],
            QoS-postcond: {
                effects: [
                    cost := PayFee(amt)
                ],
                constraints: [
                    latency > 0,
                    cost <= 10,
                    trust > 10
                ]
            },
            ok-postcond: {
                effects: [],
                constraints: [
                    succ = True,
                    r = ok
                ]
            },
            err-postcond: {
                effects: [],
                constraints: [
                    succ = False,
                    r = err
                ]
            }
        },
        {
            name: GetPrice,
            params: [
                productId: int
            ],
            returns: { price: int },
            precond: [
                wellFormed(productId) = 1
            ],
            QoS-postcond: {
                effects: [],
                constraints: [
                    latency <= 10,
                    cost <= 10,
                    trust > 10
                ]
            },
            ok-postcond: {
                effects: [],
                constraints: [
                    succ = True,
                    price > 0
                ]
            },
            err-postcond: {
                effects: [],
                constraints: [
                    succ = False,
                    price = err
                ]
            }
        }
    ]
}